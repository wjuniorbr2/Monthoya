<Application x:Class="Monthoya.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Monthoya.Desktop"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="MonthoyaInkColor">#10233F</Color>
            <Color x:Key="MonthoyaMutedColor">#617089</Color>
            <Color x:Key="MonthoyaAccentColor">#005A9E</Color>
            <Color x:Key="MonthoyaAccentDarkColor">#003A66</Color>
            <Color x:Key="MonthoyaAccentLightColor">#E5F1FB</Color>
            <Color x:Key="MonthoyaSurfaceColor">#FFFFFF</Color>
            <Color x:Key="MonthoyaSoftColor">#F2F7FF</Color>
            <Color x:Key="MonthoyaLineColor">#D7E3F5</Color>

            <SolidColorBrush x:Key="InkBrush" Color="{StaticResource MonthoyaInkColor}" />
            <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MonthoyaMutedColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource MonthoyaAccentColor}" />
            <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource MonthoyaAccentDarkColor}" />
            <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource MonthoyaAccentLightColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource MonthoyaSurfaceColor}" />
            <SolidColorBrush x:Key="SoftBrush" Color="{StaticResource MonthoyaSoftColor}" />
            <SolidColorBrush x:Key="LineBrush" Color="{StaticResource MonthoyaLineColor}" />

            <DropShadowEffect x:Key="CardShadow" BlurRadius="18" ShadowDepth="5" Direction="270" Opacity="0.22" Color="#0A1E3F" />
            <DropShadowEffect x:Key="SoftShadow" BlurRadius="16" ShadowDepth="4" Direction="270" Opacity="0.24" Color="#071B44" />
            <DropShadowEffect x:Key="TabShadow" BlurRadius="12" ShadowDepth="3" Direction="270" Opacity="0.12" Color="#10233F" />
            <DropShadowEffect x:Key="NavTextOutline" BlurRadius="1.8" ShadowDepth="0" Opacity="0.95" Color="#000711" />

            <Style TargetType="Window"><Setter Property="FontFamily" Value="Segoe UI" /><Setter Property="Background" Value="#F5F8FF" /><Setter Property="Icon" Value="Assets/Monthoya.ico" /></Style>
            <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{StaticResource InkBrush}" /></Style>
            <Style TargetType="TextBox"><Setter Property="MinHeight" Value="38" /><Setter Property="Padding" Value="12,7" /><Setter Property="BorderBrush" Value="{StaticResource LineBrush}" /><Setter Property="BorderThickness" Value="1" /><Setter Property="Background" Value="#FBFDFF" /><Setter Property="VerticalContentAlignment" Value="Center" /></Style>
            <Style TargetType="PasswordBox"><Setter Property="MinHeight" Value="38" /><Setter Property="Padding" Value="12,7" /><Setter Property="BorderBrush" Value="{StaticResource LineBrush}" /><Setter Property="BorderThickness" Value="1" /><Setter Property="Background" Value="#FBFDFF" /><Setter Property="VerticalContentAlignment" Value="Center" /></Style>
            <Style TargetType="ComboBox"><Setter Property="MinHeight" Value="38" /><Setter Property="Padding" Value="8,4" /></Style>

            <Style x:Key="NavLabelText" TargetType="TextBlock"><Setter Property="Foreground" Value="White" /><Setter Property="FontWeight" Value="ExtraBold" /><Setter Property="FontSize" Value="15" /><Setter Property="TextOptions.TextFormattingMode" Value="Display" /><Setter Property="TextOptions.TextRenderingMode" Value="ClearType" /></Style>
            <Style x:Key="NavIconText" TargetType="TextBlock"><Setter Property="Foreground" Value="White" /><Setter Property="FontFamily" Value="Segoe MDL2 Assets" /><Setter Property="FontSize" Value="15" /><Setter Property="Width" Value="22" /><Setter Property="VerticalAlignment" Value="Center" /><Setter Property="TextOptions.TextFormattingMode" Value="Display" /><Setter Property="TextOptions.TextRenderingMode" Value="ClearType" /></Style>
            <Style x:Key="ShellTabIconText" TargetType="TextBlock"><Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" /><Setter Property="FontFamily" Value="Segoe MDL2 Assets" /><Setter Property="FontSize" Value="13" /><Setter Property="Width" Value="18" /><Setter Property="Margin" Value="0,0,7,0" /><Setter Property="VerticalAlignment" Value="Center" /></Style>

            <Style x:Key="MenuScrollBarThumb" TargetType="{x:Type Thumb}"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="{x:Type Thumb}"><Border Width="6" Background="#8AFFFFFF" CornerRadius="3" /></ControlTemplate></Setter.Value></Setter></Style>
            <Style x:Key="MenuVerticalScrollBar" TargetType="{x:Type ScrollBar}"><Setter Property="Width" Value="12" /><Setter Property="Background" Value="Transparent" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="{x:Type ScrollBar}"><Grid Width="{TemplateBinding Width}" Background="Transparent"><Rectangle Width="1" RadiusX="0.5" RadiusY="0.5" Fill="#38FFFFFF" HorizontalAlignment="Center" /><Track x:Name="PART_Track" IsDirectionReversed="True"><Track.DecreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" /></Track.DecreaseRepeatButton><Track.Thumb><Thumb Style="{StaticResource MenuScrollBarThumb}" /></Track.Thumb><Track.IncreaseRepeatButton><RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" /></Track.IncreaseRepeatButton></Track></Grid></ControlTemplate></Setter.Value></Setter></Style>

            <Style x:Key="IconToolButton" TargetType="Button"><Setter Property="Width" Value="34" /><Setter Property="Height" Value="34" /><Setter Property="Padding" Value="0" /><Setter Property="Background" Value="Transparent" /><Setter Property="Foreground" Value="Black" /><Setter Property="BorderBrush" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /><Setter Property="FontFamily" Value="Segoe UI" /><Setter Property="FontSize" Value="14" /><Setter Property="Cursor" Value="Hand" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"><ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#E5E5E5" /></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Background" Value="#D5D5D5" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
            <Style x:Key="IconToolButtonDanger" TargetType="Button" BasedOn="{StaticResource IconToolButton}" />

            <Style x:Key="PrimaryButton" TargetType="Button"><Setter Property="MinHeight" Value="40" /><Setter Property="Padding" Value="18,8" /><Setter Property="Background" Value="{StaticResource AccentBrush}" /><Setter Property="Foreground" Value="White" /><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" /><Setter Property="BorderThickness" Value="1" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Cursor" Value="Hand" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}" TextElement.Foreground="White"><ContentPresenter TextElement.Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"><ContentPresenter.Resources><Style TargetType="TextBlock"><Setter Property="Foreground" Value="White" /></Style></ContentPresenter.Resources></ContentPresenter></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#004578" /><Setter TargetName="Root" Property="BorderBrush" Value="#004578" /></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Root" Property="Background" Value="{StaticResource AccentDarkBrush}" /><Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" /></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="Root" Property="Opacity" Value="0.55" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>

            <Style x:Key="SecondaryButton" TargetType="Button"><Setter Property="MinHeight" Value="38" /><Setter Property="Padding" Value="14,7" /><Setter Property="Background" Value="White" /><Setter Property="Foreground" Value="{StaticResource InkBrush}" /><Setter Property="BorderBrush" Value="{StaticResource LineBrush}" /><Setter Property="BorderThickness" Value="1" /><Setter Property="Cursor" Value="Hand" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}" TextElement.Foreground="{TemplateBinding Foreground}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="{StaticResource AccentLightBrush}" /><Setter TargetName="Root" Property="BorderBrush" Value="#9FC5E8" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
            <Style x:Key="AddTabButton" TargetType="Button"><Setter Property="Width" Value="42" /><Setter Property="MinHeight" Value="42" /><Setter Property="Padding" Value="0" /><Setter Property="Background" Value="Transparent" /><Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}" /><Setter Property="BorderBrush" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /><Setter Property="FontSize" Value="28" /><Setter Property="FontWeight" Value="ExtraBold" /><Setter Property="Cursor" Value="Hand" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8" TextElement.Foreground="{TemplateBinding Foreground}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#14005A9E" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
            <Style x:Key="NavButton" TargetType="Button"><Setter Property="MinHeight" Value="38" /><Setter Property="Padding" Value="14,7" /><Setter Property="Background" Value="Transparent" /><Setter Property="Foreground" Value="White" /><Setter Property="BorderBrush" Value="Transparent" /><Setter Property="BorderThickness" Value="0" /><Setter Property="FontWeight" Value="ExtraBold" /><Setter Property="HorizontalContentAlignment" Value="Left" /><Setter Property="Cursor" Value="Hand" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" TextElement.Foreground="{TemplateBinding Foreground}"><ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" RecognizesAccessKey="True" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#1AFFFFFF" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
            <Style x:Key="SelectedNavButton" TargetType="Button" BasedOn="{StaticResource NavButton}"><Setter Property="Background" Value="#80367BFF" /><Setter Property="Foreground" Value="White" /><Setter Property="Effect" Value="{StaticResource SoftShadow}" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="#8EB5FF" BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}" Effect="{TemplateBinding Effect}"><ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" RecognizesAccessKey="True" /></Border></ControlTemplate></Setter.Value></Setter></Style>
            <Style x:Key="ShellTabButton" TargetType="Button"><Setter Property="MinHeight" Value="42" /><Setter Property="Padding" Value="14,8" /><Setter Property="Background" Value="#E8EDF6" /><Setter Property="Foreground" Value="#4B5565" /><Setter Property="BorderBrush" Value="#D6DEEA" /><Setter Property="BorderThickness" Value="1" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Cursor" Value="Hand" /><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8,8,0,0" Padding="{TemplateBinding Padding}" TextElement.Foreground="{TemplateBinding Foreground}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True" /></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#F4F7FB" /></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
            <Style x:Key="ShellTabButtonActive" TargetType="Button" BasedOn="{StaticResource ShellTabButton}"><Setter Property="Background" Value="White" /><Setter Property="Foreground" Value="#3B4250" /><Setter Property="BorderBrush" Value="#E3ECFB" /><Setter Property="BorderThickness" Value="1,1,1,0" /><Setter Property="Effect" Value="{StaticResource CardShadow}" /></Style>
            <Style x:Key="CardBorder" TargetType="Border"><Setter Property="Background" Value="{StaticResource SurfaceBrush}" /><Setter Property="BorderBrush" Value="#E3ECFB" /><Setter Property="BorderThickness" Value="1" /><Setter Property="CornerRadius" Value="8" /><Setter Property="Padding" Value="18" /><Setter Property="Effect" Value="{StaticResource CardShadow}" /></Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>