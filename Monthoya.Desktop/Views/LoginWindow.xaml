<Window x:Class="Monthoya.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monthoya Consultoria Imobiliária"
        Width="880"
        Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#F5F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="34">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#071A3E" Offset="0" />
                    <GradientStop Color="#0A5FE8" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center">
                <Image Source="/Assets/Logo_angle_small.png"
                       Width="240"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,22" />
                <TextBlock Text="Monthoya Consultoria Imobiliária"
                           Foreground="#EAF2FF"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,8,0,0" />
                <TextBlock Text="Paranavaí - PR"
                           Foreground="#BED3FF"
                           Margin="0,4,0,0" />
                <TextBlock Text="Gestão imobiliária integrada"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,28,0,0" />
                <Border Margin="0,36,0,0"
                        Background="#20FFFFFF"
                        CornerRadius="8"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Locações, contratos, pagamentos, documentos e livro caixa em um só lugar."
                                   Foreground="White"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="54">
            <Border Style="{StaticResource CardBorder}" VerticalAlignment="Center">
                <StackPanel>
                    <DockPanel>
                        <Image Source="/Assets/Icon_Monthoya.png"
                               Width="42"
                               Height="42"
                               DockPanel.Dock="Left"
                               Margin="0,0,12,0" />
                        <TextBlock Text="Entrar"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <TextBlock Text="Use seu login e senha cadastrados."
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,10,0,24" />

                    <TextBlock Text="Login" FontWeight="SemiBold" />
                    <TextBox x:Name="LoginNameBox" Margin="0,6,0,16" />

                    <TextBlock Text="Senha" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordBox" Margin="0,6,0,18" />

                    <TextBlock x:Name="ErrorText"
                               Foreground="#B42318"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <Button Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            IsDefault="True"
                            Click="LoginButton_Click"
                            Content="Entrar" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
