<Window x:Class="Monthoya.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Entrar no Monthoya"
        Width="880"
        Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource AccentBrush}" Padding="34">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Monthoya"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="SemiBold" />
                <TextBlock Text="Gestao imobiliaria"
                           Foreground="#DDF5EF"
                           FontSize="16"
                           Margin="0,8,0,0" />
                <Border Margin="0,36,0,0"
                        Background="#20FFFFFF"
                        CornerRadius="8"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Locacoes, contratos, pagamentos e documentos em uma rotina unica."
                                   Foreground="White"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Paranavai - PR"
                                   Foreground="#DDF5EF"
                                   Margin="0,18,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="54">
            <Border Style="{StaticResource CardBorder}" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Entrar"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Use seu e-mail e senha cadastrados."
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,6,0,24" />

                    <TextBlock Text="E-mail" FontWeight="SemiBold" />
                    <TextBox x:Name="EmailBox" Margin="0,6,0,16" />

                    <TextBlock Text="Senha" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordBox" Margin="0,6,0,18" />

                    <TextBlock x:Name="ErrorText"
                               Foreground="#B42318"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <Button Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Click="LoginButton_Click"
                            Content="Entrar" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
