<Window x:Class="Monthoya.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monthoya Consultoria Imobiliária"
        Width="940"
        Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#F5F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border>
            <Border.Background>
                <ImageBrush ImageSource="/Assets/Login_image.jpg" Stretch="UniformToFill" />
            </Border.Background>
            <Grid>
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#3A06142E" Offset="0" />
                            <GradientStop Color="#D8051028" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <Grid Margin="34">
                    <StackPanel VerticalAlignment="Bottom"
                                Margin="0,0,0,84"
                                TextElement.Foreground="White">
                        <TextBlock Text="Gestão imobiliária integrada"
                                   Foreground="White"
                                   FontSize="23"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Plataforma digital para locações, vendas, contratos, pagamentos, documentos e gestão contábil."
                                   Foreground="#E7F0FF"
                                   FontSize="14"
                                   LineHeight="20"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,34" />

                        <TextBlock Text="Monthoya Consultoria Imobiliária"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Rua Getúlio Vargas, 668 - Centro"
                                   Foreground="#D9E7FF"
                                   Margin="0,6,0,0" />
                        <TextBlock Text="Paranavaí - Paraná — 87702-000"
                                   Foreground="#D9E7FF"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Bottom"
                                HorizontalAlignment="Right"
                                TextElement.Foreground="#C8DAF8">
                        <TextBlock Text="Designed and coded by"
                                   FontFamily="Cascadia Code, Consolas"
                                   FontSize="10"
                                   TextAlignment="Right" />
                        <TextBlock Text="Waldomiro S C Jr"
                                   FontFamily="Cascadia Code, Consolas"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   TextAlignment="Right"
                                   Margin="0,3,0,0" />
                        <TextBlock Text="wjuniorbr@hotmail.com"
                                   FontFamily="Cascadia Code, Consolas"
                                   FontSize="10"
                                   TextAlignment="Right"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="54">
            <Border Style="{StaticResource CardBorder}" VerticalAlignment="Center">
                <StackPanel>
                    <DockPanel>
                        <Image Source="/Assets/Login_icon_small.png"
                               Width="58"
                               Height="42"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"
                               DockPanel.Dock="Left"
                               Margin="0,0,12,0" />
                        <TextBlock Text="Entrar"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <TextBlock Text="Use seu login e senha cadastrados."
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,10,0,24" />

                    <TextBlock Text="Login" FontWeight="SemiBold" />
                    <TextBox x:Name="LoginNameBox" Margin="0,6,0,16" />

                    <TextBlock Text="Senha" FontWeight="SemiBold" />
                    <PasswordBox x:Name="PasswordBox" Margin="0,6,0,18" />

                    <TextBlock x:Name="ErrorText"
                               Foreground="#B42318"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <Button Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            IsDefault="True"
                            Click="LoginButton_Click"
                            Content="Entrar" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
