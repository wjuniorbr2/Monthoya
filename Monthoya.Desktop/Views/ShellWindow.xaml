<Window x:Class="Monthoya.Desktop.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Monthoya Consultoria Imobiliária"
        Width="1360"
        Height="840"
        MinWidth="1200"
        MinHeight="760"
        WindowStyle="None"
        ResizeMode="CanResize"
        StateChanged="ShellWindow_StateChanged"
        WindowStartupLocation="CenterScreen">
        <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="7"
                            CornerRadius="10"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid Background="#F5F8FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="0" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Floating window controls anchored to the absolute top-right corner -->
        <StackPanel Orientation="Horizontal"
                    Grid.RowSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="200"
                    Margin="0,0,0,0"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Button x:Name="TitleBarMinimizeButtonTopRight"
                    Width="40"
                    Height="28"
                    Click="TitleBarMinimizeButton_Click"
                    Style="{StaticResource IconToolButton}"
                    ToolTip="Minimizar"
                    AutomationProperties.Name="Minimizar">
                <TextBlock Text="-"
                           FontSize="18"
                           FontWeight="SemiBold"
                           LineHeight="18"
                           TextAlignment="Center"
                           Foreground="White" />
            </Button>
            <Button x:Name="TitleBarMaximizeButton"
                    Width="40"
                    Height="28"
                    Click="TitleBarMaximizeButton_Click"
                    Style="{StaticResource IconToolButton}"
                    ToolTip="Maximizar/Restaurar"
                    AutomationProperties.Name="Maximizar">
                <TextBlock Text="□"
                           FontSize="15"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="White" />
            </Button>
            <Button Width="40"
                    Height="28"
                    Click="TitleBarCloseButton_Click"
                    Style="{StaticResource IconToolButtonDanger}"
                    ToolTip="Fechar"
                    AutomationProperties.Name="Fechar">
                <TextBlock Text="X"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           Foreground="White" />
            </Button>
        </StackPanel>

        <Button x:Name="NotificationBellButton"
                Grid.RowSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="44"
                Height="34"
                Margin="0,34,16,0"
                Panel.ZIndex="201"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                Cursor="Hand"
                Click="NotificationBellButton_Click"
                ToolTip="Notificações"
                shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <TextBlock Text="&#xEA8F;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="17"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#0F172A" />
                <Border x:Name="NotificationBadge"
                        MinWidth="18"
                        Height="18"
                        Padding="4,0"
                        CornerRadius="9"
                        Background="#B42318"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-8,-8,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="NotificationBadgeText"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Button>
        <Popup x:Name="NotificationPopup"
               PlacementTarget="{Binding ElementName=NotificationBellButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               Panel.ZIndex="202">
            <Border Width="380"
                    Margin="0,8,0,0"
                    Padding="14"
                    Background="White"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="Notificações" FontSize="17" FontWeight="SemiBold" DockPanel.Dock="Left" />
                        <Button Style="{StaticResource SecondaryButton}" DockPanel.Dock="Right" Content="Central" Click="OpenNotificationCenterButton_Click" />
                    </DockPanel>
                    <ItemsControl x:Name="NotificationRecentItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource SecondaryButton}" Click="NotificationPopupItem_Click" Tag="{Binding Id}" Margin="0,0,0,8" HorizontalContentAlignment="Stretch">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding BodyPreview}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding Priority}" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="NotificationPopupEmptyText"
                               Text="Nenhuma notificação recente."
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Visibility="Collapsed" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Content="Marcar todas como lidas" Click="MarkAllNotificationsReadButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Invisible top drag strip covering full width so the user can drag the window from the top area -->
        <Border Background="Transparent"
                Grid.RowSpan="2"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Height="32"
                Panel.ZIndex="199"
                MouseLeftButtonDown="TopDragArea_MouseLeftButtonDown" />

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border BorderBrush="#DDE7F8"
                BorderThickness="0,0,1,0"
                Background="#05163A"
                Padding="18,190,18,18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Image Grid.RowSpan="2"
                       Source="/Assets/Side_panel.png"
                       Stretch="UniformToFill"
                       VerticalAlignment="Top"
                       HorizontalAlignment="Center"
                       Margin="-18,-190,-18,-18"
                       IsHitTestVisible="False" />

                <ScrollViewer Grid.Row="0"
                              VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource MenuVerticalScrollBar}" />
                    </ScrollViewer.Resources>
                    <StackPanel>
                        <Button x:Name="DashboardNavButton"
                                Style="{StaticResource SelectedNavButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10"
                                Click="DashboardNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE80F;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Tela Inicial" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="LocacoesNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="LocacoesNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE8A1;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Loca&#xE7;&#xF5;es" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="PessoasNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="PessoasNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE716;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Pessoas" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ImoveisNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="ImoveisNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE80F;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Im&#xF3;veis" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ChavesNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="ChavesNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE8D7;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Chaves" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NotificacoesNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="NotificacoesNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xEA8F;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Notificações" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="FinanceiroNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="FinanceiroNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="$" FontFamily="Segoe UI Black" FontSize="17" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Financeiro" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BoletosNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="BoletosNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE8C7;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Boletos" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NotasFiscaisNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="NotasFiscaisNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE9D9;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Notas Fiscais" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DocumentosNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="DocumentosNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE8A5;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Documentos" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="RelatoriosNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="RelatoriosNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE9D2;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Relatórios" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DimobNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="DimobNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE9F9;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="DIMOB" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ManutencoesNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="ManutencoesNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE90F;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Manutenções" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="VistoriasNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="VistoriasNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE721;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Vistorias" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ConfiguracoesNavButton" Style="{StaticResource NavButton}" HorizontalAlignment="Stretch" Margin="0,0,0,10" Click="ConfiguracoesNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE713;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Configurações" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DiagnosticsNavButton"
                                Style="{StaticResource NavButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10"
                                Click="DiagnosticsNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE950;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Diagnósticos" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="UsersNavButton"
                                Style="{StaticResource NavButton}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10"
                                Click="UsersNavButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource NavIconText}" Text="&#xE77B;" />
                                <TextBlock Style="{StaticResource NavLabelText}" Text="Usuários" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="1">
                    <Button BorderThickness="0"
                            Padding="0"
                            Margin="0,0,0,14"
                            HorizontalContentAlignment="Stretch"
                            Cursor="Hand"
                            Click="LogoutPrompt_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="IdentityLinkRoot"
                                        Background="Transparent"
                                        CornerRadius="8"
                                        Padding="12,10">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="IdentityLinkRoot" Property="Background" Value="#2BFFFFFF" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="IdentityLinkRoot" Property="Background" Value="#3DFFFFFF" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel>
                            <TextBlock x:Name="CurrentUserText"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="CurrentRoleText"
                                       Foreground="#BED3FF"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}"
                            HorizontalAlignment="Stretch"
                            Click="LogoutButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource NavIconText}" Text="&#xE8AC;" />
                            <TextBlock Style="{StaticResource NavLabelText}" Text="Sair" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="24,24,24,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        Margin="10,22,0,-1"
                        Panel.ZIndex="2"
                        x:Name="TopDragArea">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="TabsPanel"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,0" />
                </ScrollViewer>
                <Button Style="{StaticResource AddTabButton}"
                        Margin="8,0,0,0"
                        Click="AddTabButton_Click"
                        Content="+"
                        ToolTip="Nova aba" AutomationProperties.Name="Nova aba" />
            </StackPanel>
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Padding="22"
                    BorderThickness="1,0,1,1"
                    Margin="0,0,0,0">
                <Grid>
                    <Grid x:Name="DashboardPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Tela Inicial"
                                           FontSize="30"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </DockPanel>

                        <UniformGrid Grid.Row="1"
                                     Columns="4"
                                     Margin="0,22,0,22">
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Imóveis"
                                               Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock x:Name="TotalPropertiesText"
                                               FontSize="26"
                                               FontWeight="SemiBold"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Para locação"
                                               Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock x:Name="AvailableRentalsText"
                                               FontSize="26"
                                               FontWeight="SemiBold"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="Contratos ativos"
                                               Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock x:Name="ActiveContractsText"
                                               FontSize="26"
                                               FontWeight="SemiBold"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Aluguéis pendentes"
                                               Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock x:Name="PendingRentText"
                                               FontSize="26"
                                               FontWeight="SemiBold"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="2"
                              Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="360" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardBorder}" Padding="0">
                                <Grid>
                                    <wv2:WebView2 x:Name="PropertyMap" />
                                    <Button Style="{StaticResource PrimaryButton}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,18,18"
                                            Click="RefreshDashboardButton_Click"
                                            Content="Atualizar mapa" />
                                    <Border x:Name="MapFallback"
                                            Visibility="Collapsed"
                                            Background="{StaticResource SoftBrush}"
                                            Padding="24">
                                        <TextBlock x:Name="MapFallbackText"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource CardBorder}"
                                    Margin="18,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Imóveis no mapa"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="DashboardStatusText"
                                               Foreground="{StaticResource MutedBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,14" />
                                    <ListBox x:Name="MapPropertiesList"
                                             BorderThickness="0"
                                             MinHeight="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E1EAE6"
                                                        BorderThickness="0,0,0,1"
                                                        Padding="0,10">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Code}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding AddressLine}"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding RentalPrice, StringFormat=R$ {0:N2}}"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid x:Name="UsersPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Usuários"
                                           FontSize="30"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Gerencie acessos do sistema."
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Style="{StaticResource SecondaryButton}"
                                    DockPanel.Dock="Right"
                                    HorizontalAlignment="Right"
                                    Click="NewUserButton_Click"
                                    Content="Novo usuário" />
                        </DockPanel>

                        <Grid Grid.Row="1" Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="360" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource CardBorder}" Padding="0">
                                <DataGrid x:Name="UsersGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionChanged="UsersGrid_SelectionChanged"
                                          BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nome" Binding="{Binding DisplayName}" Width="*" />
                                        <DataGridTextColumn Header="Login" Binding="{Binding LoginName}" Width="*" />
                                        <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="*" />
                                        <DataGridTextColumn Header="Perfil" Binding="{Binding RoleLabel}" Width="*" />
                                        <DataGridTextColumn Header="Acessos" Binding="{Binding AccessLabel}" Width="*" />
                                        <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding IsActive}" Width="64" ElementStyle="{StaticResource ModernGridCheckBoxStyle}" EditingElementStyle="{StaticResource ModernGridCheckBoxStyle}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <Border Grid.Column="1"
                                    Style="{StaticResource CardBorder}"
                                    Margin="18,0,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Cadastro"
                                                   FontSize="20"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="Senha obrigatória somente para novo usuário."
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,16" />

                                        <TextBlock Text="Nome" FontWeight="SemiBold" />
                                        <TextBox x:Name="UserNameBox" Margin="0,6,0,12" />

                                        <TextBlock Text="Login" FontWeight="SemiBold" />
                                        <TextBox x:Name="UserLoginNameBox" Margin="0,6,0,12" />

                                        <TextBlock Text="E-mail" FontWeight="SemiBold" />
                                        <TextBox x:Name="UserEmailBox" Margin="0,6,0,12" />

                                        <TextBlock Text="Perfil" FontWeight="SemiBold" />
                                        <ComboBox x:Name="UserRoleBox"
                                                  Margin="0,6,0,12"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Role"
                                                  SelectionChanged="UserRoleBox_SelectionChanged" />

                                        <TextBlock Text="Acessos do usuário normal"
                                                   FontWeight="SemiBold" />
                                        <Border Background="{StaticResource SoftBrush}"
                                                BorderBrush="{StaticResource LineBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,6,0,12">
                                            <StackPanel>
                                                <TextBlock x:Name="AccessHelpText"
                                                           Text="Administradores e desenvolvedores mantêm acesso ao cadastro de usuários por regra. Para usuários normais, marque se ele também pode cadastrar, editar, ativar e desativar usuários."
                                                           Foreground="{StaticResource MutedBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,0,0,8" />
                                                <CheckBox x:Name="UserManagementAccessBox"
                                                          Content="Cadastro de usuários"
                                                          Margin="0,3" />
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="Senha inicial" FontWeight="SemiBold" />
                                        <PasswordBox x:Name="UserPasswordBox" Margin="0,6,0,14" />

                                        <TextBlock x:Name="UserErrorText"
                                                   Foreground="#B42318"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,14" />

                                        <Button Style="{StaticResource PrimaryButton}"
                                                HorizontalAlignment="Stretch"
                                                Click="SaveUserButton_Click"
                                                Content="Salvar" />
                                        <Button x:Name="ToggleUserActiveButton"
                                                Style="{StaticResource SecondaryButton}"
                                                HorizontalAlignment="Stretch"
