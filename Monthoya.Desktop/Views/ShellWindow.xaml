                                                    </StackPanel>
                                                    <StackPanel Width="160" Margin="0,0,14,12">
                                                        <TextBlock Text="Finalidade" FontWeight="SemiBold" />
                                                        <ComboBox x:Name="ImovelFinalidadeBox" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Width="160" Margin="0,0,14,12">
                                                        <TextBlock Text="Status" FontWeight="SemiBold" />
                                                        <ComboBox x:Name="ImovelStatusBox" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                </WrapPanel>
                                                <TextBlock Text="ENDEREÇO:" FontWeight="SemiBold" Margin="0,6,0,8" />
                                                <WrapPanel>
                                                    <StackPanel Width="150" Margin="0,0,14,12"><TextBlock Text="CEP" FontWeight="SemiBold" /><TextBox x:Name="ImovelCepBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="300" Margin="0,0,14,12"><TextBlock Text="Rua" FontWeight="SemiBold" /><TextBox x:Name="ImovelRuaBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="90" Margin="0,0,14,12"><TextBlock Text="Número" FontWeight="SemiBold" /><TextBox x:Name="ImovelNumeroBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="180" Margin="0,0,14,12"><TextBlock Text="Complemento" FontWeight="SemiBold" /><TextBox x:Name="ImovelComplementoBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="180" Margin="0,0,14,12"><TextBlock Text="Bairro" FontWeight="SemiBold" /><TextBox x:Name="ImovelBairroBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="180" Margin="0,0,14,12"><TextBlock Text="Cidade" FontWeight="SemiBold" /><TextBox x:Name="ImovelCidadeBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="80" Margin="0,0,14,12"><TextBlock Text="Estado" FontWeight="SemiBold" /><TextBox x:Name="ImovelEstadoBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="120" Margin="0,0,14,12" Visibility="Collapsed"><TextBlock Text="Latitude" FontWeight="SemiBold" /><TextBox x:Name="ImovelLatitudeBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="120" Margin="0,0,14,12" Visibility="Collapsed"><TextBlock Text="Longitude" FontWeight="SemiBold" /><TextBox x:Name="ImovelLongitudeBox" Margin="0,6,0,0" /></StackPanel>
                                                </WrapPanel>
                                                <TextBlock Text="VALORES E CARACTERÍSTICAS:" FontWeight="SemiBold" Margin="0,6,0,8" />
                                                <WrapPanel>
                                                    <StackPanel Width="130" Margin="0,0,14,12"><TextBlock Text="Aluguel" FontWeight="SemiBold" /><TextBox x:Name="ImovelValorAluguelBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="130" Margin="0,0,14,12"><TextBlock Text="Venda" FontWeight="SemiBold" /><TextBox x:Name="ImovelValorVendaBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="130" Margin="0,0,14,12"><TextBlock Text="Condomínio" FontWeight="SemiBold" /><TextBox x:Name="ImovelValorCondominioBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="130" Margin="0,0,14,12"><TextBlock Text="IPTU" FontWeight="SemiBold" /><TextBox x:Name="ImovelValorIptuBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="130" Margin="0,0,14,12"><TextBlock Text="Coleta de lixo" FontWeight="SemiBold" /><TextBox x:Name="ImovelColetaLixoBox" Margin="0,6,0,0" /></StackPanel>
                                                </WrapPanel>
                                                <WrapPanel>
                                                    <StackPanel Width="90" Margin="0,0,14,12"><TextBlock Text="Quartos" FontWeight="SemiBold" /><TextBox x:Name="ImovelQuartosBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="90" Margin="0,0,14,12"><TextBlock Text="Suítes" FontWeight="SemiBold" /><TextBox x:Name="ImovelSuitesBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="90" Margin="0,0,14,12"><TextBlock Text="Banheiros" FontWeight="SemiBold" /><TextBox x:Name="ImovelBanheirosBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="90" Margin="0,0,14,12"><TextBlock Text="Garagens" FontWeight="SemiBold" /><TextBox x:Name="ImovelVagasBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="120" Margin="0,0,14,12"><TextBlock Text="Área construída" FontWeight="SemiBold" /><TextBox x:Name="ImovelAreaConstruidaBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="120" Margin="0,0,14,12"><TextBlock Text="Área terreno" FontWeight="SemiBold" /><TextBox x:Name="ImovelAreaTerrenoBox" Margin="0,6,0,0" /></StackPanel>
                                                    <CheckBox x:Name="ImovelMobiliadoBox" Content="Mobiliado" Margin="0,24,18,12" />
                                                    <CheckBox x:Name="ImovelAceitaPetsBox" Content="Aceita pets" Margin="0,24,18,12" />
                                                </WrapPanel>
                                                <TextBlock Text="CADASTROS DE UTILIDADE:" FontWeight="SemiBold" Margin="0,6,0,8" />
                                                <WrapPanel>
                                                    <StackPanel Width="190" Margin="0,0,14,12"><TextBlock Text="Matrícula Sanepar" FontWeight="SemiBold" /><TextBox x:Name="ImovelSaneparBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="190" Margin="0,0,14,12"><TextBlock Text="Matrícula Copel" FontWeight="SemiBold" /><TextBox x:Name="ImovelCopelBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="190" Margin="0,0,14,12"><TextBlock Text="Inscri&#xE7;&#xE3;o imobili&#xE1;ria" FontWeight="SemiBold" /><TextBox x:Name="ImovelIptuInscricaoBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="190" Margin="0,0,14,12"><TextBlock Text="Cadastro do im&#xF3;vel" FontWeight="SemiBold" /><TextBox x:Name="ImovelIptuCadastroBox" Margin="0,6,0,0" /></StackPanel>
                                                </WrapPanel>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Fotos e arquivos">
                                            <StackPanel Margin="0,14,0,0">
                                                <TextBlock Text="Mídia do imóvel" FontWeight="SemiBold" />
                                                <TextBlock Text="Separe fotos públicas, fotos privadas, documentos e fotos de vistoria. Fotos de vistoria são privadas por padrão e não vão para site/app." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,12" />
                                                <WrapPanel>
                                                    <StackPanel Width="360" Margin="0,0,14,12">
                                                        <TextBlock Text="Arquivo" FontWeight="SemiBold" />
                                                        <DockPanel Margin="0,6,0,0">
                                                            <Button x:Name="BrowseImovelImagemButton" DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" Click="BrowseImovelImagemButton_Click" Content="Selecionar" Margin="8,0,0,0" />
                                                            <TextBox x:Name="ImovelImagemArquivoBox" />
                                                        </DockPanel>
                                                    </StackPanel>
                                                    <StackPanel Width="240" Margin="0,0,14,12">
                                                        <TextBlock Text="Categoria" FontWeight="SemiBold" />
                                                        <ComboBox x:Name="ImovelMediaCategoryBox" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Width="320" Margin="0,0,14,12">
                                                        <TextBlock Text="Legenda" FontWeight="SemiBold" />
                                                        <TextBox x:Name="ImovelImagemLegendaBox" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Width="90" Margin="0,0,14,12">
                                                        <TextBlock Text="Ordem" FontWeight="SemiBold" />
                                                        <TextBox x:Name="ImovelImagemOrdemBox" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                </WrapPanel>
                                                <WrapPanel>
                                                    <CheckBox x:Name="ImovelImagemPublicaBox" Content="Foto pública do imóvel" Margin="0,0,18,12" />
                                                    <CheckBox x:Name="ImovelImagemCapaBox" Content="Usar como capa" Margin="0,0,18,12" />
                                                </WrapPanel>
                                                <TextBlock x:Name="ImovelImagemErrorText" Foreground="#B42318" TextWrapping="Wrap" Margin="0,0,0,10" />
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                    <Button x:Name="SaveImovelImagemButton" Style="{StaticResource PrimaryButtonSmall}" HorizontalAlignment="Left" Click="SaveImovelImagemButton_Click" Content="Adicionar mídia" />
                                                    <Button x:Name="BrowseImovelImagensBulkButton" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Click="BrowseImovelImagensBulkButton_Click" Content="Selecionar em lote" Margin="10,0,0,0" />
                                                </StackPanel>
                                                <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl x:Name="ImovelImagensGrid">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="142" Height="156" Margin="0,0,12,12" Padding="8" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="6" Background="White">
                                                                    <StackPanel>
                                                                        <Border Height="78" Background="#F3F4F6" CornerRadius="4">
                                                                            <Grid>
                                                                                <Image Source="{Binding PreviewPath}" Stretch="UniformToFill" />
                                                                                <TextBlock Text="{Binding FileKind}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" />
                                                                            </Grid>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,8,0,2" />
                                                                        <TextBlock Text="{Binding MediaCategory}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Text="{Binding Status}" Foreground="{StaticResource MutedBrush}" TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Chaves">
                                            <StackPanel Margin="0,14,0,0">
                                                <WrapPanel>
                                                    <StackPanel Width="220" Margin="0,0,14,12"><TextBlock Text="Posse atual da chave" FontWeight="SemiBold" /><ComboBox x:Name="ImovelChavePosseBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel x:Name="ImovelChaveCodigoPanel" Width="160" Margin="0,0,14,12"><TextBlock Text="Código/etiqueta" FontWeight="SemiBold" /><TextBox x:Name="ImovelChaveCodigoBox" Margin="0,6,0,0" /></StackPanel>
                                                    <CheckBox x:Name="ImovelChaveAutorizacaoBox" Content="Autorização necessária antes da visita" Margin="0,24,18,12" />
                                                </WrapPanel>
                                                <WrapPanel x:Name="ImovelChaveContatoPanel">
                                                    <StackPanel Width="220" Margin="0,0,14,12"><TextBlock Text="Quem está com a chave" FontWeight="SemiBold" /><TextBox x:Name="ImovelChaveQuemTemBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="180" Margin="0,0,14,12"><TextBlock Text="Telefone/WhatsApp" FontWeight="SemiBold" /><TextBox x:Name="ImovelChaveTelefoneBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="220" Margin="0,0,14,12"><TextBlock Text="Contato" FontWeight="SemiBold" /><TextBox x:Name="ImovelChaveContatoNomeBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="160" Margin="0,0,14,12"><TextBlock Text="Documento" FontWeight="SemiBold" /><TextBox x:Name="ImovelChaveContatoDocumentoBox" Margin="0,6,0,0" /></StackPanel>
                                                </WrapPanel>
                                                <WrapPanel x:Name="ImovelChaveRetiradaPanel">
                                                    <StackPanel Width="360" Margin="0,0,14,12"><TextBlock Text="Local para retirar a chave" FontWeight="SemiBold" /><TextBox x:Name="ImovelChaveLocalBox" Margin="0,6,0,0" /></StackPanel>
                                                    <StackPanel Width="220" Margin="0,0,14,12"><TextBlock Text="Melhor horário" FontWeight="SemiBold" /><TextBox x:Name="ImovelChaveHorarioBox" Margin="0,6,0,0" /></StackPanel>
                                                </WrapPanel>
                                                <TextBlock Text="Observações sobre chaves" FontWeight="SemiBold" />
                                                <TextBox x:Name="ImovelChaveObservacoesBox" AcceptsReturn="True" Height="64" TextWrapping="Wrap" Margin="0,6,0,12" />
                                                <TextBlock Text="Retiradas e devoluções de chave ficam no módulo Chaves." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Vistorias">
                                            <StackPanel Margin="0,14,0,0">
                                                <TextBlock Text="Vistorias vinculadas ao imóvel" FontWeight="SemiBold" />
                                                <TextBlock Text="Crie o registro base da vistoria aqui. Ambientes, itens, muitas fotos, comparação entrada/saída e análise por IA já estão preparados no modelo para as próximas etapas." TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,12" />
                                                <WrapPanel>
                                                    <StackPanel Width="220" Margin="0,0,14,12">
                                                        <TextBlock Text="Tipo de vistoria" FontWeight="SemiBold" />
                                                        <ComboBox x:Name="ImovelVistoriaTipoBox" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Width="160" Margin="0,0,14,12">
                                                        <TextBlock Text="Data" FontWeight="SemiBold" />
                                                        <DatePicker x:Name="ImovelVistoriaDataBox" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Width="220" Margin="0,0,14,12">
                                                        <TextBlock Text="Responsável" FontWeight="SemiBold" />
                                                        <TextBox x:Name="ImovelVistoriaResponsavelBox" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Width="220" Margin="0,0,14,12">
                                                        <TextBlock Text="Status" FontWeight="SemiBold" />
                                                        <ComboBox x:Name="ImovelVistoriaStatusBox" Margin="0,6,0,0" />
                                                    </StackPanel>
                                                </WrapPanel>
                                                <TextBlock Text="Descrição geral" FontWeight="SemiBold" />
                                                <TextBox x:Name="ImovelVistoriaDescricaoBox" AcceptsReturn="True" Height="70" TextWrapping="Wrap" Margin="0,6,0,12" />
                                                <TextBlock Text="Observações" FontWeight="SemiBold" />
                                                <TextBox x:Name="ImovelVistoriaObservacoesBox" AcceptsReturn="True" Height="60" TextWrapping="Wrap" Margin="0,6,0,12" />
                                                <TextBlock x:Name="ImovelVistoriaErrorText" Foreground="#B42318" TextWrapping="Wrap" Margin="0,0,0,10" />
                                                <Button x:Name="SaveImovelVistoriaButton" Style="{StaticResource PrimaryButtonSmall}" HorizontalAlignment="Left" Click="SaveImovelVistoriaButton_Click" Content="Adicionar vistoria" Margin="0,0,0,14" />
                                                <DataGrid x:Name="ImovelVistoriasGrid"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          MaxHeight="220"
                                                          VerticalScrollBarVisibility="Auto"
                                                          BorderThickness="0">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="2*" />
                                                        <DataGridTextColumn Header="Data" Binding="{Binding DataVistoria}" Width="*" />
                                                        <DataGridTextColumn Header="Responsável" Binding="{Binding Responsavel}" Width="2*" />
                                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                                                        <DataGridTextColumn Header="Observações" Binding="{Binding Observacoes}" Width="2*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Publicação">
                                            <StackPanel Margin="0,14,0,0">
                                                <TextBlock Text="Informações públicas para site/app" FontWeight="SemiBold" />
                                                <TextBlock Text="Por padrão, o site/app mostra apenas bairro e cidade. Marque endereço completo somente quando o proprietário autorizar." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                                <WrapPanel>
                                                    <CheckBox x:Name="ImovelPublicarSiteBox" Content="Publicar no site" Margin="0,0,18,12" />
                                                    <CheckBox x:Name="ImovelPublicarAppBox" Content="Publicar no app" Margin="0,0,18,12" />
                                                    <CheckBox x:Name="ImovelDestaqueBox" Content="Destaque" Margin="0,0,18,12" />
                                                    <CheckBox x:Name="ImovelMostrarEnderecoCompletoBox" Content="Exibir endereço completo publicamente" Margin="0,0,18,12" />
                                                </WrapPanel>
                                                <StackPanel Width="260" Margin="0,0,0,12">
                                                    <TextBlock Text="Modo de exibição do endereço público" FontWeight="SemiBold" />
                                                    <ComboBox x:Name="ImovelEnderecoPublicoModoBox" Margin="0,6,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="Descrição pública (usada no site/app para clientes)" FontWeight="SemiBold" />
                                                <TextBox x:Name="ImovelDescricaoPublicaBox" AcceptsReturn="True" Height="94" TextWrapping="Wrap" Margin="0,6,0,12" />
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Observações internas">
                                            <StackPanel Margin="0,14,0,0">
                                                <TextBlock Text="Descrição interna (não aparece no site/app)" FontWeight="SemiBold" />
                                                <TextBlock Text="Use este campo para problemas, negociação, manutenção, comportamento do proprietário e notas privadas da imobiliária." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,8" />
                                                <TextBox x:Name="ImovelDescricaoBox" AcceptsReturn="True" Height="94" TextWrapping="Wrap" Margin="0,0,0,12" />
                                                <TextBlock Text="Observações internas" FontWeight="SemiBold" />
                                                <TextBox x:Name="ImovelObservacoesBox" AcceptsReturn="True" Height="94" TextWrapping="Wrap" Margin="0,6,0,12" />
                                            </StackPanel>
                                        </TabItem>
                                    </TabControl>
                                    <TextBlock x:Name="ImovelErrorText" Foreground="#B42318" TextWrapping="Wrap" Margin="0,12,0,12" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="SaveImovelButton" Style="{StaticResource PrimaryButtonSmall}" HorizontalAlignment="Left" Click="SaveImovelButton_Click" Content="Salvar imóvel" />
                                        <Button x:Name="CancelImovelEditButton" Style="{StaticResource SecondaryButton}" Margin="10,0,0,0" HorizontalAlignment="Left" Click="CancelImovelEditButton_Click" Content="Cancelar edição" Visibility="Collapsed" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Grid x:Name="ChavesPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Chaves" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock Text="Retiradas, devoluções e atrasos das chaves dos imóveis." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Style="{StaticResource SecondaryButton}" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="ReloadChavesButton_Click" Content="Atualizar" />
                        </DockPanel>
                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ChavesSearchBox"
                                     TextChanged="ChavesSearchBox_TextChanged"
                                     ToolTip="Pesquisar por imóvel, código, pessoa, telefone ou motivo" />
                            <ComboBox x:Name="ChavesStatusFilterBox"
                                      Grid.Column="1"
                                      Margin="10,0,0,0"
                                      SelectionChanged="ChavesStatusFilterBox_SelectionChanged" />
                        </Grid>
                        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0" Margin="0,16,0,16">
                            <DataGrid x:Name="ChavesGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      BorderThickness="0"
                                      SelectionChanged="ChavesGrid_SelectionChanged">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Em atraso">
                                                <Setter Property="Background" Value="#FFF2F1" />
                                                <Setter Property="Foreground" Value="#B42318" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Imóvel" Binding="{Binding Imovel}" Width="2*" />
                                    <DataGridTextColumn Header="Código" Binding="{Binding ChaveCodigo}" Width="*" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                                    <DataGridTextColumn Header="Retirado por" Binding="{Binding RetiradoPorNome}" Width="1.4*" />
                                    <DataGridTextColumn Header="Telefone" Binding="{Binding RetiradoPorTelefone}" Width="*" />
                                    <DataGridTextColumn Header="Relação" Binding="{Binding RetiradoPorRelacao}" Width="*" />
                                    <DataGridTextColumn Header="Motivo" Binding="{Binding Motivo}" Width="1.4*" />
                                    <DataGridTextColumn Header="Retirado em" Binding="{Binding RetiradoEm, StringFormat=dd/MM/yyyy HH:mm}" Width="1.1*" />
                                    <DataGridTextColumn Header="Previsão" Binding="{Binding PrevisaoDevolucaoEm, StringFormat=dd/MM/yyyy HH:mm}" Width="1.1*" />
                                    <DataGridTextColumn Header="Devolvido em" Binding="{Binding DevolvidoEm, StringFormat=dd/MM/yyyy HH:mm}" Width="1.1*" />
                                    <DataGridTextColumn Header="Observações" Binding="{Binding Observacoes}" Width="1.6*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="Registrar retirada" FontSize="18" FontWeight="SemiBold" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <StackPanel Width="320" Margin="0,0,14,12">
                                            <TextBlock Text="Imóvel" FontWeight="SemiBold" />
                                            <ComboBox x:Name="ChavesImovelBox" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="130" Margin="0,0,14,12">
                                            <TextBlock Text="Código" FontWeight="SemiBold" />
                                            <TextBox x:Name="ChavesCodigoBox" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="210" Margin="0,0,14,12">
                                            <TextBlock Text="Retirado por" FontWeight="SemiBold" />
                                            <TextBox x:Name="ChavesRetiradoPorNomeBox" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="160" Margin="0,0,14,12">
                                            <TextBlock Text="Telefone" FontWeight="SemiBold" />
                                            <TextBox x:Name="ChavesRetiradoPorTelefoneBox" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="150" Margin="0,0,14,12">
                                            <TextBlock Text="Documento" FontWeight="SemiBold" />
                                            <TextBox x:Name="ChavesRetiradoPorDocumentoBox" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="160" Margin="0,0,14,12">
                                            <TextBlock Text="Relação" FontWeight="SemiBold" />
                                            <TextBox x:Name="ChavesRetiradoPorRelacaoBox" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="270" Margin="0,0,14,12">
                                            <TextBlock Text="Previsão de devolução" FontWeight="SemiBold" />
                                            <DatePicker x:Name="ChavesPrevisaoBox" Width="150" HorizontalAlignment="Left" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="280" Margin="0,0,14,12">
                                            <TextBlock Text="Motivo" FontWeight="SemiBold" />
                                            <TextBox x:Name="ChavesMotivoBox" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel Width="360" Margin="0,0,14,12">
                                            <TextBlock Text="Observações" FontWeight="SemiBold" />
                                            <TextBox x:Name="ChavesObservacoesBox" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </WrapPanel>
                                    <Button x:Name="SaveChaveRetiradaButton" Style="{StaticResource PrimaryButtonSmall}" HorizontalAlignment="Left" Click="SaveChaveRetiradaButton_Click" Content="Registrar retirada" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Registrar devolução" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock x:Name="ChavesSelectedMovimentoText" Text="Selecione uma retirada ativa na lista." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,12" />
                                    <TextBlock Text="Recebido por" FontWeight="SemiBold" />
                                    <TextBox x:Name="ChavesDevolvidoParaBox" Margin="0,6,0,12" />
                                    <TextBlock Text="Observações" FontWeight="SemiBold" />
                                    <TextBox x:Name="ChavesDevolucaoObservacoesBox" AcceptsReturn="True" Height="64" TextWrapping="Wrap" Margin="0,6,0,12" />
                                    <TextBlock x:Name="ChavesErrorText" Foreground="#B42318" TextWrapping="Wrap" Margin="0,0,0,12" />
                                    <Button x:Name="ReturnChaveButton" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Click="ReturnChaveButton_Click" Content="Registrar devolução" IsEnabled="False" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid x:Name="NotificacoesPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Central de notificações" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock Text="Mensagens internas, alertas do sistema e avisos que precisam de confirmação." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Content="Marcar todas como lidas" Click="MarkAllNotificationsReadButton_Click" Margin="0,0,10,0" />
                                <Button Style="{StaticResource SecondaryButton}" Content="Atualizar" Click="ReloadNotificationsButton_Click" Margin="0,0,10,0" />
                                <Button x:Name="NotificationHistoryToggleButton" Style="{StaticResource SecondaryButton}" Content="Histórico" Click="NotificationHistoryToggleButton_Click" />
                            </StackPanel>
                        </DockPanel>
                        <Grid Grid.Row="1" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="170" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="NotificationsSearchBox"
                                     TextChanged="NotificationsSearchBox_TextChanged"
                                     ToolTip="Pesquisar por título ou mensagem" />
                            <ComboBox x:Name="NotificationsCategoryFilterBox"
                                      Grid.Column="1"
                                      Margin="10,0,0,0"
                                      SelectionChanged="NotificationsFilter_SelectionChanged" />
                            <ComboBox x:Name="NotificationsPriorityFilterBox"
                                      Grid.Column="2"
                                      Margin="10,0,0,0"
                                      SelectionChanged="NotificationsFilter_SelectionChanged" />
                            <CheckBox x:Name="NotificationsUnreadOnlyBox"
                                      Grid.Column="3"
                                      Content="Não lidas"
                                      VerticalAlignment="Center"
                                      Margin="10,0,0,0"
                                      Checked="NotificationsFilter_SelectionChanged"
                                      Unchecked="NotificationsFilter_SelectionChanged" />
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="520" />
                                <ColumnDefinition Width="1.7*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition x:Name="NotificationMainListRow" Height="*" />
                                        <RowDefinition x:Name="NotificationHistoryRow" Height="0" />
                                    </Grid.RowDefinitions>
                                    <Grid x:Name="NotificationActivePanel" Background="White">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Background="{StaticResource AccentLightBrush}" Padding="12,8" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,0,1">
                                            <TextBlock Text="Notificações ativas" FontSize="16" FontWeight="SemiBold" />
                                        </Border>
                                        <DataGrid x:Name="NotificationsGrid"
                                                  Grid.Row="1"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  BorderThickness="0"
                                                  MinHeight="130"
                                                  SelectionChanged="NotificationsGrid_SelectionChanged">
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="Lida" Binding="{Binding IsRead}" Width="70" ElementStyle="{StaticResource ModernGridCheckBoxStyle}" EditingElementStyle="{StaticResource ModernGridCheckBoxStyle}" />
                                                <DataGridTextColumn Header="Prioridade" Binding="{Binding Priority}" Width="0.8*" />
                                                <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="1.1*" />
                                                <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="1.7*" />
                                                <DataGridTextColumn Header="Resumo" Binding="{Binding BodyPreview}" Width="2.1*" />
                                                <DataGridTextColumn Header="Criada em" Binding="{Binding CreatedAtUtc, StringFormat=dd/MM/yyyy HH:mm}" Width="1.1*" />
                                                <DataGridCheckBoxColumn Header="Confirmação" Binding="{Binding RequiresAcknowledgement}" Width="110" ElementStyle="{StaticResource ModernGridCheckBoxStyle}" EditingElementStyle="{StaticResource ModernGridCheckBoxStyle}" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                    <Grid x:Name="NotificationHistoryPanel" Grid.Row="1" Visibility="Collapsed" Background="#F5F8FF" Margin="0,14,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Background="#EAF2FF" Padding="12,8" BorderBrush="{StaticResource AccentBrush}" BorderThickness="0,2,0,1">
                                            <TextBlock Text="Histórico" FontSize="16" FontWeight="SemiBold" />
                                        </Border>
                                        <DataGrid x:Name="NotificationHistoryGrid"
                                                  Grid.Row="1"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  BorderThickness="0"
                                                  MinHeight="220"
                                                  SelectionChanged="NotificationHistoryGrid_SelectionChanged">
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="Lida" Binding="{Binding IsRead}" Width="70" ElementStyle="{StaticResource ModernGridCheckBoxStyle}" EditingElementStyle="{StaticResource ModernGridCheckBoxStyle}" />
                                                <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="1.2*" />
                                                <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="1.8*" />
                                                <DataGridTextColumn Header="Resumo" Binding="{Binding BodyPreview}" Width="2.2*" />
                                                <DataGridTextColumn Header="Criada em" Binding="{Binding CreatedAtUtc, StringFormat=dd/MM/yyyy HH:mm}" Width="1.1*" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Grid>
                            </Border>
                            <ScrollViewer Margin="0,0,18,0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="Nova mensagem / notificação" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock Text="Título" FontWeight="SemiBold" Margin="0,12,0,0" />
                                            <TextBox x:Name="NewNotificationTitleBox" Margin="0,6,0,10" />
                                            <TextBlock Text="Mensagem" FontWeight="SemiBold" />
                                            <TextBox x:Name="NewNotificationBodyBox" AcceptsReturn="True" Height="90" TextWrapping="Wrap" Margin="0,6,0,10" />
                                            <WrapPanel>
                                                <StackPanel Width="180" Margin="0,0,12,10">
                                                    <TextBlock Text="Prioridade" FontWeight="SemiBold" />
                                                    <ComboBox x:Name="NewNotificationPriorityBox" Margin="0,6,0,0" />
                                                </StackPanel>
                                                <StackPanel Width="180" Margin="0,0,0,10">
                                                    <TextBlock Text="Categoria" FontWeight="SemiBold" />
                                                    <ComboBox x:Name="NewNotificationCategoryBox" Margin="0,6,0,0" />
                                                </StackPanel>
                                            </WrapPanel>
                                            <TextBlock Text="Destinatários" FontWeight="SemiBold" />
                                            <ListBox x:Name="NewNotificationRecipientsList"
                                                     SelectionMode="Multiple"
                                                     DisplayMemberPath="DisplayName"
                                                     MaxHeight="120"
                                                     Margin="0,6,0,10" />
                                            <CheckBox x:Name="NewNotificationRequiresAckBox" Content="Exigir confirmação" Margin="0,0,0,8" />
                                            <CheckBox Content="No sistema" IsChecked="True" IsEnabled="False" Margin="0,0,0,6" />
                                            <CheckBox x:Name="NewNotificationEmailBox" Content="E-mail (configurar na próxima etapa)" IsEnabled="False" Margin="0,0,0,6" />
                                            <CheckBox x:Name="NewNotificationWhatsAppBox" Content="WhatsApp não configurado ainda" IsEnabled="False" Margin="0,0,0,10" />
                                            <TextBlock x:Name="NewNotificationErrorText" Foreground="#B42318" TextWrapping="Wrap" Margin="0,0,0,10" />
                                            <Button Style="{StaticResource PrimaryButtonSmall}" Content="Enviar mensagem" HorizontalAlignment="Left" Click="CreateNotificationButton_Click" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource CardBorder}" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Detalhes" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock x:Name="NotificationDetailsTitleText" Text="Selecione uma notificação." FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,12,0,4" />
                                            <TextBlock x:Name="NotificationDetailsMetaText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                            <TextBlock x:Name="NotificationDetailsBodyText" TextWrapping="Wrap" Margin="0,0,0,12" />
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Button x:Name="NotificationMarkReadButton" Style="{StaticResource SecondaryButton}" Content="Marcar como lida" Click="NotificationMarkReadButton_Click" IsEnabled="False" Margin="0,0,8,0" />
                                                <Button x:Name="NotificationAcknowledgeButton" Style="{StaticResource SecondaryButton}" Content="Confirmar" Click="NotificationAcknowledgeButton_Click" IsEnabled="False" Margin="0,0,8,0" />
                                                <Button x:Name="NotificationDismissButton" Style="{StaticResource SecondaryButton}" Content="Arquivar" Click="NotificationDismissButton_Click" IsEnabled="False" Margin="0,0,8,0" />
                                                <Button x:Name="NotificationActionButton" Style="{StaticResource SecondaryButton}" Content="Abrir" Click="NotificationActionButton_Click" IsEnabled="False" />
                                            </StackPanel>
                                            <DataGrid x:Name="NotificationDeliveriesGrid"
                                                      AutoGenerateColumns="False"
                                                      IsReadOnly="True"
                                                      MaxHeight="150"
                                                      BorderThickness="0">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Canal" Binding="{Binding Channel}" Width="*" />
                                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                                                    <DataGridTextColumn Header="Destino" Binding="{Binding Destination}" Width="1.5*" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <Grid x:Name="ModulePanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock x:Name="ModuleTitleText" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock x:Name="ModuleSubtitleText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="ModuleOpenButton" Style="{StaticResource SecondaryButton}" Content="Abrir" Click="ModuleOpenButton_Click" Margin="0,0,8,0" IsEnabled="False" />
                                <Button x:Name="ModuleReloadButton" Style="{StaticResource SecondaryButton}" Content="Atualizar" Click="ModuleReloadButton_Click" Margin="0,0,8,0" />
                                <Button x:Name="ModulePrimaryActionButton" Style="{StaticResource SecondaryButton}" Click="ModulePrimaryActionButton_Click" />
                            </StackPanel>
                        </DockPanel>
                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,18,0,18">
                            <TextBlock x:Name="ModuleNoticeText" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" />
                        </Border>
                        <TextBox x:Name="ModuleSearchBox"
                                 Grid.Row="2"
                                 Margin="0,0,0,18"
                                 TextChanged="ModuleSearchBox_TextChanged"
                                 ToolTip="Pesquisar nesta lista" />
                        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="0">
                            <DataGrid x:Name="ModuleGrid" AutoGenerateColumns="True" IsReadOnly="True" BorderThickness="0" SelectionChanged="ModuleGrid_SelectionChanged" />
                        </Border>
                    </Grid>

                    <Grid x:Name="DiagnosticsPanel" Visibility="Collapsed">
                        <Border Style="{StaticResource CardBorder}" Width="620" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Diagnósticos"
                                           FontSize="28"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Área técnica disponível apenas para o perfil Desenvolvedor."
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,18" />
                                <TextBlock x:Name="DiagnosticsText"
                                           FontFamily="Consolas"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Grid>
</Window>

