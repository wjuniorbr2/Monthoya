                                                <TextBlock Text="CPF do cônjuge" FontWeight="SemiBold" />
                                                <TextBox x:Name="PessoaConjugeCpfBox" Margin="0,6,0,12" />
                                                <TextBlock Text="Nascimento do cônjuge" FontWeight="SemiBold" />
