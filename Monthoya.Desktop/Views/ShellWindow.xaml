                                                <TextBox x:Name="PessoaJuridicaEnderecoEmpresaBox" Margin="0,6,0,12" />
                                                <TextBlock Text="Nome do responsável" FontWeight="SemiBold" />
                                                <TextBox x:Name="PessoaResponsavelNomeBox" Margin="0,6,0,12" />
