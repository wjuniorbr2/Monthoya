                    <Grid x:Name="ImoveisPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Imóveis" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock Text="Cadastro inicial de imóveis vinculados a proprietário." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Style="{StaticResource SecondaryButton}" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="ReloadImoveisButton_Click" Content="Atualizar" />
                        </DockPanel>
                        <TextBox x:Name="ImoveisSearchBox"
                                 Grid.Row="1"
                                 Margin="0,16,0,0"
                                 TextChanged="ImoveisSearchBox_TextChanged"
                                 ToolTip="Pesquisar por rua, bairro ou proprietário" />
                        <Grid Grid.Row="2" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="360" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource CardBorder}" Padding="0">
                                <DataGrid x:Name="ImoveisGrid" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Endereço" Binding="{Binding Endereco}" Width="2*" />
                                        <DataGridTextColumn Header="Bairro" Binding="{Binding Bairro}" Width="*" />
                                        <DataGridTextColumn Header="Proprietário" Binding="{Binding Proprietario}" Width="2*" />
                                        <DataGridTextColumn Header="Finalidade" Binding="{Binding Finalidade}" Width="*" />
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" />
                                        <DataGridTextColumn Header="Aluguel" Binding="{Binding ValorAluguel, StringFormat=R$ {0:N2}}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="18,0,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="Novo imóvel" FontSize="20" FontWeight="SemiBold" />
                                        <TextBlock Text="Selecione uma pessoa com função Proprietário." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,6,0,16" />
                                        <TextBlock Text="Proprietário" FontWeight="SemiBold" />
                                        <ComboBox x:Name="ImovelProprietarioBox" DisplayMemberPath="Nome" SelectedValuePath="Id" Margin="0,6,0,12" />
                                        <TextBlock Text="Rua" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelRuaBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Número" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelNumeroBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Complemento" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelComplementoBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Bairro" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelBairroBox" Margin="0,6,0,12" />
                                        <TextBlock Text="CEP" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelCepBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Tipo do imóvel" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelTipoBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Matrícula Sanepar" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelSaneparBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Matrícula Copel" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelCopelBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Matrícula IPTU" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelIptuBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Valor do aluguel" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelValorAluguelBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Valor de venda" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelValorVendaBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Finalidade" FontWeight="SemiBold" />
                                        <ComboBox x:Name="ImovelFinalidadeBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Latitude" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelLatitudeBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Longitude" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelLongitudeBox" Margin="0,6,0,12" />
                                        <TextBlock Text="Descrição" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelDescricaoBox" AcceptsReturn="True" Height="74" TextWrapping="Wrap" Margin="0,6,0,12" />
                                        <TextBlock Text="Observações" FontWeight="SemiBold" />
                                        <TextBox x:Name="ImovelObservacoesBox" AcceptsReturn="True" Height="74" TextWrapping="Wrap" Margin="0,6,0,12" />
                                        <TextBlock x:Name="ImovelErrorText" Foreground="#B42318" TextWrapping="Wrap" Margin="0,0,0,12" />
                                        <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Click="SaveImovelButton_Click" Content="Salvar imóvel" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid x:Name="ModulePanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock x:Name="ModuleTitleText" FontSize="30" FontWeight="SemiBold" />
                                <TextBlock x:Name="ModuleSubtitleText" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button x:Name="ModulePrimaryActionButton" Style="{StaticResource SecondaryButton}" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="ModulePrimaryActionButton_Click" />
                        </DockPanel>
                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,18,0,18">
                            <TextBlock x:Name="ModuleNoticeText" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" />
                        </Border>
                        <TextBox x:Name="ModuleSearchBox"
                                 Grid.Row="2"
                                 Margin="0,0,0,18"
                                 TextChanged="ModuleSearchBox_TextChanged"
                                 ToolTip="Pesquisar nesta lista" />
                        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="0">
                            <DataGrid x:Name="ModuleGrid" AutoGenerateColumns="True" IsReadOnly="True" BorderThickness="0" />
                        </Border>
                    </Grid>

                    <Grid x:Name="DiagnosticsPanel" Visibility="Collapsed">
                        <Border Style="{StaticResource CardBorder}" Width="620" HorizontalAlignment="Left" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Diagnósticos"
                                           FontSize="28"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Área técnica disponível apenas para o perfil Desenvolvedor."
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,6,0,18" />
                                <TextBlock x:Name="DiagnosticsText"
                                           FontFamily="Consolas"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Grid>
</Window>
