                                                <TextBlock Text="Estado civil do responsável" FontWeight="SemiBold" />
                                                <TextBox x:Name="PessoaResponsavelEstadoCivilBox" Margin="0,6,0,12" />
                                                <TextBlock Text="Nacionalidade do responsável" FontWeight="SemiBold" />
