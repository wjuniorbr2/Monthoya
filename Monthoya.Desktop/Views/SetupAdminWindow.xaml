<Window x:Class="Monthoya.Desktop.Views.SetupAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Primeiro acesso"
        Width="800"
        Height="620"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Background="#F5F8FF">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Padding="28">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#071A3E" Offset="0" />
                    <GradientStop Color="#0A5FE8" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel VerticalAlignment="Center">
                <Image Source="/Assets/Logo_angle.png"
                       Width="220"
                       Stretch="Uniform"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,28" />
                <TextBlock Text="Sistema imobiliario"
                           Foreground="#DDF5EF"
                           FontSize="16"
                           Margin="0,8,0,0" />
                <TextBlock Text="Crie o primeiro administrador para proteger o acesso ao sistema."
                           Foreground="#EAF2FF"
                           TextWrapping="Wrap"
                           Margin="0,32,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="28,24"
                Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <DockPanel>
                        <Image Source="/Assets/Icon_Monthoya.png"
                               Width="40"
                               Height="40"
                               DockPanel.Dock="Left"
                               Margin="0,0,12,0" />
                        <TextBlock Text="Primeiro administrador"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                    <TextBlock Text="Nao existe usuario cadastrado. Defina o acesso inicial."
                               Foreground="{StaticResource MutedBrush}"
                               Margin="0,10,0,18" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                <TextBlock Text="Nome" FontWeight="SemiBold" />
                <TextBox x:Name="NameBox" Margin="0,6,0,12" />

                <TextBlock Text="E-mail" FontWeight="SemiBold" />
                <TextBox x:Name="EmailBox" Margin="0,6,0,12" />

                <TextBlock Text="Senha" FontWeight="SemiBold" />
                <PasswordBox x:Name="PasswordBox" Margin="0,6,0,12" />

                <TextBlock Text="Confirmar senha" FontWeight="SemiBold" />
                <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,6,0,10" />

                <TextBlock x:Name="ErrorText"
                           Foreground="#B42318"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
                </StackPanel>

                <Button Grid.Row="2"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Margin="0,14,0,0"
                        Click="CreateButton_Click"
                        Content="Criar administrador" />
            </Grid>
        </Border>
    </Grid>
</Window>
