<Window x:Class="Monthoya.Desktop.Views.SetupAdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Primeiro acesso"
        Width="760"
        Height="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="{StaticResource AccentBrush}" Padding="28">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Monthoya"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="SemiBold" />
                <TextBlock Text="Sistema imobiliario"
                           Foreground="#DDF5EF"
                           Margin="0,8,0,0" />
                <TextBlock Text="Crie o primeiro administrador para proteger o acesso ao sistema."
                           Foreground="#DDF5EF"
                           TextWrapping="Wrap"
                           Margin="0,32,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Margin="28"
                Style="{StaticResource CardBorder}">
            <StackPanel>
                <TextBlock Text="Primeiro administrador"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Text="Nao existe usuario cadastrado. Defina o acesso inicial."
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,6,0,22" />

                <TextBlock Text="Nome" FontWeight="SemiBold" />
                <TextBox x:Name="NameBox" Margin="0,6,0,14" />

                <TextBlock Text="E-mail" FontWeight="SemiBold" />
                <TextBox x:Name="EmailBox" Margin="0,6,0,14" />

                <TextBlock Text="Senha" FontWeight="SemiBold" />
                <PasswordBox x:Name="PasswordBox" Margin="0,6,0,14" />

                <TextBlock Text="Confirmar senha" FontWeight="SemiBold" />
                <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,6,0,16" />

                <TextBlock x:Name="ErrorText"
                           Foreground="#B42318"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14" />

                <Button Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Click="CreateButton_Click"
                        Content="Criar administrador" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
