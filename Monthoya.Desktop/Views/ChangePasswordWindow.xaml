<Window x:Class="Monthoya.Desktop.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alterar senha"
        Width="500"
        Height="480"
        MinWidth="460"
        MinHeight="440"
        ResizeMode="CanResize"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner">
    <Grid Background="#F5F8FF">
        <Border Margin="24" Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Alterar senha"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Confirme sua senha atual e informe a nova senha duas vezes."
                               Foreground="{StaticResource MutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Text="Senha atual" FontWeight="SemiBold" />
                    <PasswordBox x:Name="CurrentBox" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <TextBlock Text="Nova senha" FontWeight="SemiBold" />
                    <PasswordBox x:Name="NewBox" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="0,0,0,12">
                    <TextBlock Text="Confirmar nova senha" FontWeight="SemiBold" />
                    <PasswordBox x:Name="ConfirmBox" Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Row="4" MinHeight="64" Padding="0,4,0,0">
                    <TextBlock x:Name="ErrorText"
                               Foreground="#B42318"
                               TextWrapping="Wrap" />
                </Border>

                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="Cancelar"
                            Margin="0,0,10,0"
                            IsCancel="True"
                            Click="CancelButton_Click" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Alterar senha"
                            IsDefault="True"
                            Click="SaveButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
