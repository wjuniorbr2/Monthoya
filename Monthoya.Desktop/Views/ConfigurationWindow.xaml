<Window x:Class="Monthoya.Desktop.Views.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Monthoya Consultoria Imobiliária"
        Width="680"
        Height="430"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="28" Background="#F5F8FF">
        <Border Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <Image Source="/Assets/Logo_icon2.png"
                           Width="42"
                           Height="42"
                           DockPanel.Dock="Left"
                           Margin="0,0,14,0" />
                    <StackPanel>
                        <TextBlock Text="Configuração do banco de dados"
                                   FontSize="26"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Monthoya"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>

                <TextBlock x:Name="MessageText"
                           Grid.Row="1"
                           Margin="0,12,0,0"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap" />

                <Border Grid.Row="2"
                        Margin="0,24,0,0"
                        Background="{StaticResource SoftBrush}"
                        BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Use user secrets ou variáveis de ambiente. Não salve senhas no código."
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,12,0,0"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Text="dotnet user-secrets set &quot;Database:ConnectionString&quot; &quot;Host=&lt;host&gt;;Port=5432;Database=&lt;database&gt;;Username=&lt;username&gt;;Password=&lt;password&gt;&quot; --project .\Monthoya.Desktop" />
                    </StackPanel>
                </Border>

                <Button Grid.Row="3"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Right"
                        Margin="0,24,0,0"
                        Click="CloseButton_Click"
                        Content="Fechar" />
            </Grid>
        </Border>
    </Grid>
</Window>
