# Normalize text files in the repository.
* text=auto

# Keep source files normalized with LF in Git.
*.cs text eol=lf
*.xaml text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ps1 text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf

# Treat common binary assets as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.dll binary
*.exe binary
